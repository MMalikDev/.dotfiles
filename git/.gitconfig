[core]
	editor = nvim
	autocrlf = false
	compression = 9
	whitespace = error
	preloadindex = true
[init]
	defaultBranch = main
[includeIf "gitdir:~/github/private/"]
	path = ./gitconfig-private

[includeIf "gitdir:~/github/public/"]
	path = ./gitconfig-public
[user]
	name = Mohammed Malik
	email = mohammedmalik.dev+github@gmail.com
